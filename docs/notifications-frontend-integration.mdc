# Notifications - Frontend Integration Guide

Base URL: **`/api`** (example: `http://localhost:8080/api`)  
All notifications routes are protected with JWT (`Authorization: Bearer <accessToken>`).

---

## 1. TypeScript types

```typescript
export const API_BASE = '/api';

export type NotificationChannel = 'inApp' | 'email' | 'slack';
export type NotificationStatus = 'sent' | 'read' | 'archived' | 'failed';

export interface NotificationItem {
  id: string;
  userId: string;
  channel: NotificationChannel;
  status: NotificationStatus;
  referenceId: string;
  payload: Record<string, unknown>;
  failedReason: string | null;
  sentAt: string | null;
  createdAt: string;
  updatedAt: string;
}

export interface CreateNotificationBody {
  // optional, backend defaults to current JWT user when omitted
  userId?: string;
  referenceId: string; // UUID
  payload: Record<string, unknown>;
  channel?: NotificationChannel;
  status?: NotificationStatus;
  failedReason?: string;
  sentAt?: string; // ISO date string
}

export interface GetNotificationsParams {
  channel?: NotificationChannel;
  status?: NotificationStatus;
  limit?: number;
  offset?: number;
  orderBy?: 'asc' | 'desc';
  orderByField?: 'createdAt' | 'updatedAt' | 'sentAt';
}

export interface GetNotificationsResponse {
  data: NotificationItem[];
  limit?: number;
  offset?: number;
  totalCount?: number;
}

export interface ApiErrorResponse {
  error: {
    statusCode: number;
    message: string;
    error: string;
    code: string;
    metadata?: Record<string, unknown>;
    timestamp: string;
    path: string;
  };
}
```

---

## 2. HTTP endpoints

### POST `/api/notifications` (JWT)

Create notification.

- Body: `CreateNotificationBody`
- Response 201/200: `NotificationItem`

```typescript
const res = await fetch(`${API_BASE}/notifications`, {
  method: 'POST',
  headers: {
    'Content-Type': 'application/json',
    Authorization: `Bearer ${accessToken}`,
  },
  body: JSON.stringify({
    referenceId: crypto.randomUUID(),
    payload: { message: 'Webhook alert detected' },
    channel: 'inApp',
    status: 'sent',
  } satisfies CreateNotificationBody),
});

const created: NotificationItem = await res.json();
```

---

### GET `/api/notifications` (JWT)

List current user notifications with filters + pagination.

- Query: `GetNotificationsParams`
- Response 200: `GetNotificationsResponse`

```typescript
const params = new URLSearchParams({
  limit: '20',
  offset: '0',
  orderBy: 'desc',
  orderByField: 'createdAt',
  status: 'sent',
});

const res = await fetch(`${API_BASE}/notifications?${params}`, {
  headers: { Authorization: `Bearer ${accessToken}` },
});

const page: GetNotificationsResponse = await res.json();
```

---

### GET `/api/notifications/:id` (JWT)

Get one notification (scoped to current user).

- Params: `id` (UUID)
- Response 200: `NotificationItem`
- 404 when not found/not owned

```typescript
const res = await fetch(`${API_BASE}/notifications/${notificationId}`, {
  headers: { Authorization: `Bearer ${accessToken}` },
});

const item: NotificationItem = await res.json();
```

---

## 3. Frontend helper functions

```typescript
function authHeaders(token: string): HeadersInit {
  return { Authorization: `Bearer ${token}` };
}

async function parseApi<T>(res: Response): Promise<T> {
  if (!res.ok) {
    const err = (await res.json().catch(() => null)) as ApiErrorResponse | null;
    throw new Error(err?.error?.message ?? `HTTP ${res.status}`);
  }
  return res.json() as Promise<T>;
}

export async function createNotification(
  token: string,
  body: CreateNotificationBody
): Promise<NotificationItem> {
  const res = await fetch(`${API_BASE}/notifications`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', ...authHeaders(token) },
    body: JSON.stringify(body),
  });
  return parseApi<NotificationItem>(res);
}

export async function getNotifications(
  token: string,
  query: GetNotificationsParams = {}
): Promise<GetNotificationsResponse> {
  const params = new URLSearchParams();
  if (query.channel) params.set('channel', query.channel);
  if (query.status) params.set('status', query.status);
  if (query.limit != null) params.set('limit', String(query.limit));
  if (query.offset != null) params.set('offset', String(query.offset));
  if (query.orderBy) params.set('orderBy', query.orderBy);
  if (query.orderByField) params.set('orderByField', query.orderByField);

  const res = await fetch(`${API_BASE}/notifications?${params.toString()}`, {
    headers: authHeaders(token),
  });
  return parseApi<GetNotificationsResponse>(res);
}

export async function getNotificationById(
  token: string,
  id: string
): Promise<NotificationItem> {
  const res = await fetch(`${API_BASE}/notifications/${id}`, {
    headers: authHeaders(token),
  });
  return parseApi<NotificationItem>(res);
}
```

