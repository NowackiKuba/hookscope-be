## 8. Optional: typed fetch helper

```typescript
async function api<T>(
  path: string,
  options?: RequestInit & { body?: object }
): Promise<T> {
  const { body, ...init } = options ?? {};
  const headers: HeadersInit = {
    ...(init.headers as Record<string, string>),
    ...(body && { 'Content-Type': 'application/json' }),
  };
  const res = await fetch(`${API_BASE}${path}`, {
    ...init,
    headers,
    body: body ? JSON.stringify(body) : init.body,
  });
  if (!res.ok) {
    const err: ApiErrorResponse = await res.json().catch(() => ({} as ApiErrorResponse));
    throw new Error(err?.error?.message ?? res.statusText);
  }
  if (res.status === 204) return undefined as T;
  return res.json() as Promise<T>;
}

// Usage (with token from login):
const token = '…';
const auth = () => ({ Authorization: `Bearer ${token}` });

const endpoints = await api<Endpoint[]>('/endpoints', { headers: auth() });
const created = await api<Endpoint>('/endpoints', { method: 'POST', headers: auth(), body: { name: 'Test' } });
const list = await api<RequestsListResponse>(`/requests?endpointId=${id}&limit=20&offset=0`, { headers: auth() });
```
