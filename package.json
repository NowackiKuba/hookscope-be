{
  "name": "hookscope-be",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node -r tsconfig-paths/register dist/src/main",
    "migration:create": "mikro-orm migration:create",
    "migration:up": "mikro-orm migration:up",
    "migration:down": "mikro-orm migration:down",
    "migration:fresh": "mikro-orm migration:fresh",
    "seeder:create": "mikro-orm seeder:create",
    "seeder:run": "mikro-orm seeder:run",
    "seed:templates": "mikro-orm seeder:run --class=TemplatesSeeder",
    "seed:system-prompts": "mikro-orm seeder:run --class=SystemPromptSeeder",
    "seed:users": "mikro-orm seeder:run --class=UsersSeeder",
    "seed:rooms": "mikro-orm seeder:run --class=RoomsSeeder",
    "seed:reservations": "mikro-orm seeder:run --class=ReservationsSeeder",
    "seed:db": "mikro-orm seeder:run --class=DatabaseSeeder",
    "seed:packets": "mikro-orm seeder:run --class=PacketsSeeder",
    "docker:dev": "docker compose -f compose.dev.yml up --build",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@anatine/zod-nestjs": "^2.0.12",
    "@anatine/zod-openapi": "^2.2.8",
    "@anthropic-ai/sdk": "^0.80.0",
    "@mikro-orm/core": "^6.0.0",
    "@mikro-orm/migrations": "^6.0.0",
    "@mikro-orm/nestjs": "^6.0.0",
    "@mikro-orm/postgresql": "^6.0.0",
    "@mikro-orm/seeder": "^6.0.0",
    "@mikro-orm/sql-highlighter": "^1.0.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/cqrs": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/websockets": "^11.1.16",
    "@types/bcrypt": "^6.0.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.0",
    "date-fns": "^4.1.0",
    "ejs": "^3.1.10",
    "express": "^4.18.0",
    "marked": "^15.0.0",
    "nest-winston": "^1.10.0",
    "nestjs-zod": "^2.0.0",
    "node-ical": "^0.25.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfmake": "^0.3.6",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.0",
    "resend": "^4.0.0",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.1",
    "tsconfig-paths": "^4.2.0",
    "uploadthing": "^7.7.4",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@faker-js/faker": "^10.3.0",
    "@mikro-orm/cli": "^6.0.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/socket.io": "^3.0.2",
    "eslint": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "globals": "^15.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
