<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Potwierdzenie rezerwacji — Pokoje Borowa</title>
</head>
<body style="margin:0; padding:0; background-color:#F0F2F5; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#F0F2F5;">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:600px;">

          <!-- HEADER -->
          <tr>
            <td style="background-color:#111827; padding:28px 32px; text-align:center;">
              <p style="margin:0 0 6px 0; font-size:10px; font-weight:700; letter-spacing:3px; color:#6EE7B7; text-transform:uppercase;">Pokoje w górach</p>
              <p style="margin:0; font-size:26px; font-weight:700; color:#FFFFFF; letter-spacing:-0.5px;"><%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></p>
            </td>
          </tr>

          <!-- HERO -->
          <tr>
            <td style="background-color:#2D6A4F; padding:32px; text-align:center;">
              <p style="margin:0 0 12px 0; font-size:40px; line-height:1;">🏡</p>
              <p style="margin:0; font-size:22px; font-weight:700; color:#FFFFFF; line-height:1.3;">Rezerwacja potwierdzona</p>
            </td>
          </tr>

          <!-- CONTENT -->
          <tr>
            <td style="background-color:#FFFFFF; padding:40px 32px;">

              <p style="margin:0 0 8px 0; font-size:17px; font-weight:600; color:#111827;">
                Cześć, <%= typeof guest !== 'undefined' && guest && guest.firstName ? guest.firstName : 'Gościu' %>!
              </p>
              <p style="margin:0 0 16px 0; font-size:15px; line-height:1.7; color:#4B5563;">
                Dziękujemy za rezerwację. Rezerwacja nr <strong><%= typeof reservation !== 'undefined' && reservation && reservation.id ? reservation.id : '—' %></strong> została potwierdzona.
              </p>
              <p style="margin:0 0 32px 0; font-size:14px; line-height:1.6; color:#6B7280;">
                Poniżej znajdziesz szczegóły pobytu: termin, pokoje, płatności i informacje praktyczne.
              </p>

              <!-- Reservation ID -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:24px;">
                <tr>
                  <td style="background-color:#ECFDF5; border:1px solid #A7F3D0; border-radius:8px; padding:16px 20px;">
                    <p style="margin:0 0 4px 0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#065F46;">Numer rezerwacji</p>
                    <p style="margin:0; font-size:22px; font-weight:700; color:#059669; letter-spacing:0.5px;"><%= typeof reservation !== 'undefined' && reservation && reservation.id ? reservation.id : '—' %></p>
                  </td>
                </tr>
              </table>

              <!-- Guest details -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:16px; border:1px solid #E5E7EB; border-radius:8px;">
                <tr>
                  <td colspan="2" style="padding:12px 20px; border-bottom:1px solid #E5E7EB; background-color:#F9FAFB;">
                    <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6B7280;">Dane gościa</p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280; width:45%;">Imię i nazwisko</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= typeof guest !== 'undefined' && guest ? (guest.firstName || '') + ' ' + (guest.lastName || '') : '—' %></td>
                </tr>
                <% if (typeof guest !== 'undefined' && guest && guest.email) { %>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280;">E-mail</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= guest.email %></td>
                </tr>
                <% } %>
                <% if (typeof guest !== 'undefined' && guest && guest.phone) { %>
                <tr>
                  <td style="padding:13px 20px; font-size:13px; color:#6B7280;">Telefon</td>
                  <td style="padding:13px 20px; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= guest.phone %></td>
                </tr>
                <% } %>
              </table>

              <!-- Dates -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:16px; border:1px solid #E5E7EB; border-radius:8px;">
                <tr>
                  <td colspan="2" style="padding:12px 20px; border-bottom:1px solid #E5E7EB; background-color:#F9FAFB;">
                    <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6B7280;">Termin pobytu</p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280; width:45%;">Zameldowanie</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= typeof reservation !== 'undefined' && reservation && reservation.checkIn ? reservation.checkIn : '—' %></td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280;">Wymeldowanie</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= typeof reservation !== 'undefined' && reservation && reservation.checkOut ? reservation.checkOut : '—' %></td>
                </tr>
                <% if (typeof reservation !== 'undefined' && reservation && reservation.nightsCount != null) { %>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280;">Liczba nocy</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= reservation.nightsCount %></td>
                </tr>
                <% } %>
                <% if (typeof reservation !== 'undefined' && reservation && reservation.guestsCount != null) { %>
                <tr>
                  <td style="padding:13px 20px; font-size:13px; color:#6B7280;">Liczba gości</td>
                  <td style="padding:13px 20px; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= reservation.guestsCount %></td>
                </tr>
                <% } %>
              </table>

              <!-- Rooms -->
              <% if (typeof rooms !== 'undefined' && rooms && Array.isArray(rooms) && rooms.length) { %>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:16px; border:1px solid #E5E7EB; border-radius:8px;">
                <tr>
                  <td colspan="2" style="padding:12px 20px; border-bottom:1px solid #E5E7EB; background-color:#F9FAFB;">
                    <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6B7280;">Pokoje</p>
                  </td>
                </tr>
                <% rooms.forEach(function(room, i) { %>
                <tr>
                  <td style="padding:13px 20px; <%= i < rooms.length - 1 ? 'border-bottom:1px solid #F3F4F6;' : '' %> font-size:14px; font-weight:500; color:#111827;"><%= room.name || '—' %></td>
                  <td style="padding:13px 20px; <%= i < rooms.length - 1 ? 'border-bottom:1px solid #F3F4F6;' : '' %> font-size:13px; color:#6B7280; text-align:right;"><%= typeof room.pricePerNight !== 'undefined' && room.pricePerNight != null ? room.pricePerNight + ' / noc' : '' %></td>
                </tr>
                <% }); %>
              </table>
              <% } %>

              <!-- Payment summary -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:24px; border:1px solid #E5E7EB; border-radius:8px;">
                <tr>
                  <td colspan="2" style="padding:12px 20px; border-bottom:1px solid #E5E7EB; background-color:#F9FAFB;">
                    <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6B7280;">Płatności</p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280; width:50%;">Łączna kwota</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= typeof payment !== 'undefined' && payment && payment.totalAmount != null ? payment.totalAmount : '—' %></td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280;">Zaliczka (opłacona)</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:600; color:#059669; text-align:right;"><%= typeof payment !== 'undefined' && payment && payment.depositAmount != null ? payment.depositAmount : '—' %></td>
                </tr>
                <tr style="background-color:#FFFBEB;">
                  <td style="padding:14px 20px; font-size:14px; font-weight:700; color:#92400E;">Do zapłaty przy zameldowaniu</td>
                  <td style="padding:14px 20px; font-size:16px; font-weight:700; color:#D97706; text-align:right;"><%= typeof payment !== 'undefined' && payment && payment.remainingAmount != null ? payment.remainingAmount : '—' %></td>
                </tr>
              </table>

              <!-- Practical info -->
              <% if (typeof hotel !== 'undefined' && hotel) { %>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:32px; border:1px solid #E5E7EB; border-radius:8px;">
                <tr>
                  <td colspan="2" style="padding:12px 20px; border-bottom:1px solid #E5E7EB; background-color:#F9FAFB;">
                    <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6B7280;">Informacje praktyczne</p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280; width:45%;">Check-in</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= hotel.checkInTime || '—' %></td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280;">Check-out</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= hotel.checkOutTime || '—' %></td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; <%= hotel.phone || hotel.email ? 'border-bottom:1px solid #F3F4F6;' : '' %> font-size:13px; color:#6B7280;">Adres</td>
                  <td style="padding:13px 20px; <%= hotel.phone || hotel.email ? 'border-bottom:1px solid #F3F4F6;' : '' %> font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= hotel.address || '—' %></td>
                </tr>
                <% if (hotel.phone) { %>
                <tr>
                  <td style="padding:13px 20px; <%= hotel.email ? 'border-bottom:1px solid #F3F4F6;' : '' %> font-size:13px; color:#6B7280;">Telefon</td>
                  <td style="padding:13px 20px; <%= hotel.email ? 'border-bottom:1px solid #F3F4F6;' : '' %> font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= hotel.phone %></td>
                </tr>
                <% } %>
                <% if (hotel.email) { %>
                <tr>
                  <td style="padding:13px 20px; font-size:13px; color:#6B7280;">E-mail</td>
                  <td style="padding:13px 20px; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= hotel.email %></td>
                </tr>
                <% } %>
              </table>
              <% } %>

              <!-- Check-in instructions -->
              <% if (typeof hotel !== 'undefined' && hotel && hotel.checkInInstructions) { %>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:16px; border:1px solid #E5E7EB; border-radius:8px;">
                <tr>
                  <td style="padding:12px 20px; border-bottom:1px solid #E5E7EB; background-color:#F9FAFB;">
                    <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6B7280;">Instrukcja zameldowania</p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:16px 20px; font-size:14px; line-height:1.7; color:#374151; white-space:pre-line;"><%= hotel.checkInInstructions %></td>
                </tr>
              </table>
              <% } %>

              <!-- Cancellation policy -->
              <% if (typeof hotel !== 'undefined' && hotel && hotel.cancellationDeadlineHours) { %>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:16px; background-color:#FFF7ED; border:1px solid #FED7AA; border-radius:8px;">
                <tr>
                  <td style="padding:14px 20px;">
                    <p style="margin:0 0 4px 0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#9A3412;">Polityka anulowania</p>
                    <p style="margin:0; font-size:13px; line-height:1.6; color:#7C2D12;">Bezpłatne anulowanie do <strong><%= hotel.cancellationDeadlineHours %> godzin</strong> przed planowanym przyjazdem.</p>
                  </td>
                </tr>
              </table>
              <% } %>

              <!-- CTA Button -->
              <% if (typeof reservationUrl !== 'undefined' && reservationUrl) { %>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:32px;">
                <tr>
                  <td style="text-align:center;">
                    <a href="<%= reservationUrl %>" style="display:inline-block; background-color:#2D6A4F; color:#FFFFFF; font-size:15px; font-weight:600; text-decoration:none; padding:14px 32px; border-radius:8px; letter-spacing:0.3px;">Zobacz szczegóły rezerwacji →</a>
                  </td>
                </tr>
              </table>
              <% } %>

              <p style="margin:0 0 6px 0; font-size:15px; line-height:1.7; color:#4B5563;">
                Cieszymy się, że wybrałeś nasze pokoje. Czekamy na Ciebie z niecierpliwością!
              </p>
              <p style="margin:16px 0 0 0; font-size:14px; color:#4B5563;">
                Serdecznie,<br />
                <strong style="color:#111827;">Zespół <%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></strong>
              </p>
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td style="background-color:#F9FAFB; border-top:1px solid #E5E7EB; padding:24px 32px; text-align:center;">
              <p style="margin:0 0 4px 0; font-size:13px; font-weight:600; color:#374151;"><%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></p>
              <% if (typeof hotel !== 'undefined' && hotel && hotel.address) { %>
              <p style="margin:0 0 2px 0; font-size:12px; color:#9CA3AF;"><%= hotel.address %></p>
              <% } %>
              <% if (typeof hotel !== 'undefined' && hotel && hotel.phone) { %>
              <p style="margin:0 0 2px 0; font-size:12px; color:#9CA3AF;"><%= hotel.phone %></p>
              <% } %>
              <% if (typeof hotel !== 'undefined' && hotel && hotel.email) { %>
              <p style="margin:0; font-size:12px; color:#9CA3AF;"><a href="mailto:<%= hotel.email %>" style="color:#9CA3AF; text-decoration:none;"><%= hotel.email %></a></p>
              <% } %>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
