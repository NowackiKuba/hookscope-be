<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dziękujemy za pobyt — Pokoje Borowa</title>
</head>
<body style="margin:0; padding:0; background-color:#F0F2F5; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#F0F2F5;">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:600px;">

          <!-- HEADER -->
          <tr>
            <td style="background-color:#111827; padding:28px 32px; text-align:center;">
              <p style="margin:0 0 6px 0; font-size:10px; font-weight:700; letter-spacing:3px; color:#6EE7B7; text-transform:uppercase;">Pokoje w górach</p>
              <p style="margin:0; font-size:26px; font-weight:700; color:#FFFFFF; letter-spacing:-0.5px;"><%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></p>
            </td>
          </tr>

          <!-- HERO -->
          <tr>
            <td style="background-color:#1E3A5F; padding:32px; text-align:center;">
              <p style="margin:0 0 12px 0; font-size:40px; line-height:1;">⭐</p>
              <p style="margin:0; font-size:22px; font-weight:700; color:#FFFFFF; line-height:1.3;">Dziękujemy za pobyt!</p>
            </td>
          </tr>

          <!-- CONTENT -->
          <tr>
            <td style="background-color:#FFFFFF; padding:40px 32px;">

              <p style="margin:0 0 8px 0; font-size:17px; font-weight:600; color:#111827;">
                Cześć, <%= typeof guest !== 'undefined' && guest && guest.firstName ? guest.firstName : 'Gościu' %>!
              </p>
              <p style="margin:0 0 12px 0; font-size:15px; line-height:1.7; color:#4B5563;">
                Mieliśmy prawdziwą przyjemność gościć Cię w <%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %>
                <% if (typeof reservation !== 'undefined' && reservation && reservation.checkIn && reservation.checkOut) { %>
                — od <strong style="color:#111827;"><%= reservation.checkIn %></strong> do <strong style="color:#111827;"><%= reservation.checkOut %></strong><% if (reservation.nightsCount != null) { %> (<%= reservation.nightsCount %> <%= reservation.nightsCount === 1 ? 'noc' : reservation.nightsCount < 5 ? 'noce' : 'nocy' %>)<% } %>
                <% } %>.
              </p>
              <p style="margin:0 0 32px 0; font-size:15px; line-height:1.7; color:#4B5563;">
                Mamy nadzieję, że czas spędzony w górach był dla Ciebie prawdziwym odpoczynkiem i że wróci do nas przy następnej okazji.
              </p>

              <!-- Review request -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:24px; background-color:#FFFBEB; border:1px solid #FDE68A; border-radius:8px;">
                <tr>
                  <td style="padding:24px; text-align:center;">
                    <p style="margin:0 0 8px 0; font-size:24px; line-height:1;">🙏</p>
                    <p style="margin:0 0 8px 0; font-size:15px; font-weight:700; color:#92400E;">Twoja opinia wiele dla nas znaczy</p>
                    <p style="margin:0 0 20px 0; font-size:14px; line-height:1.6; color:#78350F;">
                      Jeśli masz chwilę, będziemy wdzięczni za kilka słów w Google. Pomaga to innym gościom odkryć nasze pokoje w górach.
                    </p>
                    <% if (typeof hotel !== 'undefined' && hotel && hotel.googleReviewUrl) { %>
                    <a href="<%= hotel.googleReviewUrl %>" style="display:inline-block; background-color:#D97706; color:#FFFFFF; font-size:14px; font-weight:700; text-decoration:none; padding:12px 28px; border-radius:8px; letter-spacing:0.3px;">Wystaw opinię w Google ★</a>
                    <% } %>
                  </td>
                </tr>
              </table>

              <!-- Stay summary -->
              <% if (typeof reservation !== 'undefined' && reservation && (reservation.checkIn || reservation.checkOut)) { %>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:32px; border:1px solid #E5E7EB; border-radius:8px;">
                <tr>
                  <td colspan="2" style="padding:12px 20px; border-bottom:1px solid #E5E7EB; background-color:#F9FAFB;">
                    <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6B7280;">Twój pobyt</p>
                  </td>
                </tr>
                <% if (reservation.checkIn) { %>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280; width:45%;">Zameldowanie</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= reservation.checkIn %></td>
                </tr>
                <% } %>
                <% if (reservation.checkOut) { %>
                <tr>
                  <td style="padding:13px 20px; font-size:13px; color:#6B7280;">Wymeldowanie</td>
                  <td style="padding:13px 20px; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= reservation.checkOut %></td>
                </tr>
                <% } %>
              </table>
              <% } %>

              <p style="margin:0 0 6px 0; font-size:15px; line-height:1.7; color:#4B5563;">
                Do zobaczenia na szlaku!
              </p>
              <p style="margin:16px 0 0 0; font-size:14px; color:#4B5563;">
                Serdecznie,<br />
                <strong style="color:#111827;">Zespół <%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></strong>
              </p>
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td style="background-color:#F9FAFB; border-top:1px solid #E5E7EB; padding:24px 32px; text-align:center;">
              <p style="margin:0 0 4px 0; font-size:13px; font-weight:600; color:#374151;"><%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></p>
              <% if (typeof hotel !== 'undefined' && hotel && hotel.phone) { %>
              <p style="margin:0 0 2px 0; font-size:12px; color:#9CA3AF;"><%= hotel.phone %></p>
              <% } %>
              <% if (typeof hotel !== 'undefined' && hotel && hotel.email) { %>
              <p style="margin:0; font-size:12px; color:#9CA3AF;"><a href="mailto:<%= hotel.email %>" style="color:#9CA3AF; text-decoration:none;"><%= hotel.email %></a></p>
              <% } %>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
