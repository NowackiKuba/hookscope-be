<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Płatność przyjęta — Pokoje Borowa</title>
</head>
<body style="margin:0; padding:0; background-color:#F0F2F5; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#F0F2F5;">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:600px;">

          <!-- HEADER -->
          <tr>
            <td style="background-color:#111827; padding:28px 32px; text-align:center;">
              <p style="margin:0 0 6px 0; font-size:10px; font-weight:700; letter-spacing:3px; color:#6EE7B7; text-transform:uppercase;">Pokoje w górach</p>
              <p style="margin:0; font-size:26px; font-weight:700; color:#FFFFFF; letter-spacing:-0.5px;"><%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></p>
            </td>
          </tr>

          <!-- HERO -->
          <tr>
            <td style="background-color:#1D4ED8; padding:32px; text-align:center;">
              <p style="margin:0 0 12px 0; font-size:40px; line-height:1;">💳</p>
              <p style="margin:0; font-size:22px; font-weight:700; color:#FFFFFF; line-height:1.3;">Wszystko opłacone — do zobaczenia!</p>
            </td>
          </tr>

          <!-- CONTENT -->
          <tr>
            <td style="background-color:#FFFFFF; padding:40px 32px;">

              <p style="margin:0 0 8px 0; font-size:17px; font-weight:600; color:#111827;">
                Cześć, <%= typeof guest !== 'undefined' && guest && guest.firstName ? guest.firstName : 'Gościu' %>!
              </p>
              <p style="margin:0 0 16px 0; font-size:15px; line-height:1.7; color:#4B5563;">
                Otrzymaliśmy pełną płatność za rezerwację nr <strong><%= typeof reservation !== 'undefined' && reservation && reservation.id ? reservation.id : '—' %></strong>. Wszystko opłacone — czekamy na Ciebie!
              </p>
              <p style="margin:0 0 32px 0; font-size:14px; line-height:1.6; color:#6B7280;">
                Poniżej potwierdzenie płatności oraz dane rezerwacji (termin, pokoje).
              </p>

              <!-- Payment confirmation badge -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:24px; background-color:#EFF6FF; border:1px solid #BFDBFE; border-radius:8px;">
                <tr>
                  <td colspan="2" style="padding:12px 20px; border-bottom:1px solid #BFDBFE;">
                    <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#1E40AF;">Potwierdzenie płatności</p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #DBEAFE; font-size:13px; color:#3B82F6; width:45%;">Kwota</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #DBEAFE; font-size:16px; font-weight:700; color:#1D4ED8; text-align:right;"><%= typeof payment !== 'undefined' && payment && payment.amount != null ? payment.amount : '—' %></td>
                </tr>
                <% if (typeof payment !== 'undefined' && payment && payment.paidAt) { %>
                <tr>
                  <td style="padding:13px 20px; <%= typeof payment !== 'undefined' && payment && payment.transactionId ? 'border-bottom:1px solid #DBEAFE;' : '' %> font-size:13px; color:#3B82F6;">Data płatności</td>
                  <td style="padding:13px 20px; <%= typeof payment !== 'undefined' && payment && payment.transactionId ? 'border-bottom:1px solid #DBEAFE;' : '' %> font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= payment.paidAt %></td>
                </tr>
                <% } %>
                <% if (typeof payment !== 'undefined' && payment && payment.transactionId) { %>
                <tr>
                  <td style="padding:13px 20px; font-size:13px; color:#3B82F6;">Nr transakcji</td>
                  <td style="padding:13px 20px; font-size:13px; font-weight:600; color:#111827; text-align:right;"><%= payment.transactionId %></td>
                </tr>
                <% } %>
              </table>

              <!-- Reservation details -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:24px; border:1px solid #E5E7EB; border-radius:8px;">
                <tr>
                  <td colspan="2" style="padding:12px 20px; border-bottom:1px solid #E5E7EB; background-color:#F9FAFB;">
                    <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6B7280;">Twoja rezerwacja (nr <%= typeof reservation !== 'undefined' && reservation && reservation.id ? reservation.id : '—' %>)</p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280; width:45%;">Numer rezerwacji</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:700; color:#111827; text-align:right;"><%= typeof reservation !== 'undefined' && reservation && reservation.id ? reservation.id : '—' %></td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280;">Zameldowanie</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= typeof reservation !== 'undefined' && reservation && reservation.checkIn ? reservation.checkIn : '—' %></td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; <%= (typeof reservation !== 'undefined' && reservation && reservation.nightsCount != null) || (typeof reservation !== 'undefined' && reservation && reservation.rooms && reservation.rooms.length) ? 'border-bottom:1px solid #F3F4F6;' : '' %> font-size:13px; color:#6B7280;">Wymeldowanie</td>
                  <td style="padding:13px 20px; <%= (typeof reservation !== 'undefined' && reservation && reservation.nightsCount != null) || (typeof reservation !== 'undefined' && reservation && reservation.rooms && reservation.rooms.length) ? 'border-bottom:1px solid #F3F4F6;' : '' %> font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= typeof reservation !== 'undefined' && reservation && reservation.checkOut ? reservation.checkOut : '—' %></td>
                </tr>
                <% if (typeof reservation !== 'undefined' && reservation && reservation.nightsCount != null) { %>
                <tr>
                  <td style="padding:13px 20px; <%= (typeof reservation !== 'undefined' && reservation && reservation.rooms && reservation.rooms.length) ? 'border-bottom:1px solid #F3F4F6;' : '' %> font-size:13px; color:#6B7280;">Liczba nocy</td>
                  <td style="padding:13px 20px; <%= (typeof reservation !== 'undefined' && reservation && reservation.rooms && reservation.rooms.length) ? 'border-bottom:1px solid #F3F4F6;' : '' %> font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= reservation.nightsCount %></td>
                </tr>
                <% } %>
                <% if (typeof reservation !== 'undefined' && reservation && reservation.rooms && Array.isArray(reservation.rooms) && reservation.rooms.length) { %>
                <tr>
                  <td style="padding:13px 20px; font-size:13px; color:#6B7280;">Pokoje</td>
                  <td style="padding:13px 20px; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= reservation.rooms.map(function(r) { return r.name; }).join(', ') %></td>
                </tr>
                <% } %>
              </table>

              <!-- Check-in reminder -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:32px; background-color:#F0FDF4; border:1px solid #BBF7D0; border-radius:8px;">
                <tr>
                  <td style="padding:16px 20px;">
                    <p style="margin:0 0 4px 0; font-size:13px; font-weight:700; color:#065F46;">Zameldowanie</p>
                    <p style="margin:0; font-size:13px; line-height:1.6; color:#166534;">
                      Prosimy o przybycie w ustalonej godzinie.<% if (typeof hotel !== 'undefined' && hotel && hotel.phone) { %> W razie pytań zadzwoń: <strong><%= hotel.phone %></strong><% } %>
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Check-in instructions -->
              <% if (typeof hotel !== 'undefined' && hotel && hotel.checkInInstructions) { %>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:32px; border:1px solid #E5E7EB; border-radius:8px;">
                <tr>
                  <td style="padding:12px 20px; border-bottom:1px solid #E5E7EB; background-color:#F9FAFB;">
                    <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6B7280;">Instrukcja zameldowania</p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:16px 20px; font-size:14px; line-height:1.7; color:#374151; white-space:pre-line;"><%= hotel.checkInInstructions %></td>
                </tr>
              </table>
              <% } %>

              <p style="margin:0 0 6px 0; font-size:15px; line-height:1.7; color:#4B5563;">
                Do zobaczenia wkrótce w <%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %>!
              </p>
              <p style="margin:16px 0 0 0; font-size:14px; color:#4B5563;">
                Serdecznie,<br />
                <strong style="color:#111827;">Zespół <%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></strong>
              </p>
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td style="background-color:#F9FAFB; border-top:1px solid #E5E7EB; padding:24px 32px; text-align:center;">
              <p style="margin:0 0 4px 0; font-size:13px; font-weight:600; color:#374151;"><%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></p>
              <% if (typeof hotel !== 'undefined' && hotel && hotel.phone) { %>
              <p style="margin:0 0 2px 0; font-size:12px; color:#9CA3AF;"><%= hotel.phone %></p>
              <% } %>
              <% if (typeof hotel !== 'undefined' && hotel && hotel.email) { %>
              <p style="margin:0; font-size:12px; color:#9CA3AF;"><a href="mailto:<%= hotel.email %>" style="color:#9CA3AF; text-decoration:none;"><%= hotel.email %></a></p>
              <% } %>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
