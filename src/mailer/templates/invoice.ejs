<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Faktura <%= typeof invoice !== 'undefined' && invoice && invoice.number ? invoice.number.fullNumber : '' %> — Pokoje Borowa</title>
</head>
<body style="margin:0; padding:0; background-color:#F0F2F5; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#F0F2F5;">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:600px;">

          <!-- HEADER -->
          <tr>
            <td style="background-color:#111827; padding:28px 32px; text-align:center;">
              <p style="margin:0 0 6px 0; font-size:10px; font-weight:700; letter-spacing:3px; color:#6EE7B7; text-transform:uppercase;">Pokoje w górach</p>
              <p style="margin:0; font-size:26px; font-weight:700; color:#FFFFFF; letter-spacing:-0.5px;"><%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></p>
            </td>
          </tr>

          <!-- HERO -->
          <tr>
            <td style="background-color:#2D6A4F; padding:32px; text-align:center;">
              <p style="margin:0 0 12px 0; font-size:40px; line-height:1;">🧾</p>
              <p style="margin:0; font-size:22px; font-weight:700; color:#FFFFFF; line-height:1.3;">Faktura VAT</p>
              <% if (typeof invoice !== 'undefined' && invoice && invoice.number) { %>
              <p style="margin:8px 0 0 0; font-size:15px; color:#A7F3D0; font-weight:500;"><%= invoice.number.fullNumber %></p>
              <% } %>
            </td>
          </tr>

          <!-- CONTENT -->
          <tr>
            <td style="background-color:#FFFFFF; padding:40px 32px;">

              <p style="margin:0 0 8px 0; font-size:17px; font-weight:600; color:#111827;">
                Cześć, <%= typeof guest !== 'undefined' && guest && guest.firstName ? guest.firstName : (typeof invoice !== 'undefined' && invoice && invoice.buyer ? invoice.buyer.name : 'Gościu') %>!
              </p>
              <p style="margin:0 0 32px 0; font-size:15px; line-height:1.7; color:#4B5563;">
                W załączniku znajdziesz fakturę VAT nr <strong><%= typeof invoice !== 'undefined' && invoice && invoice.number ? invoice.number.fullNumber : '—' %></strong>. Prosimy o zapoznanie się z dokumentem.
              </p>

              <!-- Invoice number -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:24px;">
                <tr>
                  <td style="background-color:#ECFDF5; border:1px solid #A7F3D0; border-radius:8px; padding:16px 20px;">
                    <p style="margin:0 0 4px 0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#065F46;">Numer faktury</p>
                    <p style="margin:0; font-size:22px; font-weight:700; color:#059669; letter-spacing:0.5px;"><%= typeof invoice !== 'undefined' && invoice && invoice.number ? invoice.number.fullNumber : '—' %></p>
                  </td>
                </tr>
              </table>

              <!-- Dates -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:16px; border:1px solid #E5E7EB; border-radius:8px;">
                <tr>
                  <td colspan="2" style="padding:12px 20px; border-bottom:1px solid #E5E7EB; background-color:#F9FAFB;">
                    <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6B7280;">Daty</p>
                  </td>
                </tr>
                <% if (typeof invoice !== 'undefined' && invoice && invoice.dates) { %>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280; width:45%;">Data wystawienia</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= invoice.dates.issueDate %></td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280;">Data sprzedaży</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= invoice.dates.saleDate %></td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; font-size:13px; color:#6B7280;">Termin płatności</td>
                  <td style="padding:13px 20px; font-size:14px; font-weight:600; color:#111827; text-align:right;"><%= invoice.dates.dueDate %></td>
                </tr>
                <% } %>
              </table>

              <!-- Seller & Buyer -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:16px;">
                <tr>
                  <td style="width:50%; padding-right:8px; vertical-align:top;">
                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="border:1px solid #E5E7EB; border-radius:8px;">
                      <tr>
                        <td style="padding:12px 16px; border-bottom:1px solid #E5E7EB; background-color:#F9FAFB;">
                          <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6B7280;">Sprzedawca</p>
                        </td>
                      </tr>
                      <% if (typeof invoice !== 'undefined' && invoice && invoice.seller) { %>
                      <tr>
                        <td style="padding:14px 16px;">
                          <p style="margin:0 0 4px 0; font-size:14px; font-weight:600; color:#111827; line-height:1.5;"><%= invoice.seller.name %></p>
                          <p style="margin:0 0 4px 0; font-size:13px; color:#4B5563; line-height:1.5;"><%= invoice.seller.address %></p>
                          <p style="margin:0 0 4px 0; font-size:12px; color:#6B7280;">NIP: <%= invoice.seller.nip %></p>
                          <p style="margin:0; font-size:12px; color:#6B7280;">Nr konta: <%= invoice.seller.bankAccount %></p>
                        </td>
                      </tr>
                      <% } %>
                    </table>
                  </td>
                  <td style="width:50%; padding-left:8px; vertical-align:top;">
                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="border:1px solid #E5E7EB; border-radius:8px;">
                      <tr>
                        <td style="padding:12px 16px; border-bottom:1px solid #E5E7EB; background-color:#F9FAFB;">
                          <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6B7280;">Nabywca</p>
                        </td>
                      </tr>
                      <% if (typeof invoice !== 'undefined' && invoice && invoice.buyer) { %>
                      <tr>
                        <td style="padding:14px 16px;">
                          <p style="margin:0 0 4px 0; font-size:14px; font-weight:600; color:#111827; line-height:1.5;"><%= invoice.buyer.name %></p>
                          <p style="margin:0 0 4px 0; font-size:13px; color:#4B5563; line-height:1.5;"><%= invoice.buyer.address %></p>
                          <% if (invoice.buyer.nip) { %>
                          <p style="margin:0 0 4px 0; font-size:12px; color:#6B7280;">NIP: <%= invoice.buyer.nip %></p>
                          <% } %>
                          <% if (invoice.buyer.email) { %>
                          <p style="margin:0; font-size:12px; color:#6B7280;"><%= invoice.buyer.email %></p>
                          <% } %>
                        </td>
                      </tr>
                      <% } %>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Items -->
              <% if (typeof invoice !== 'undefined' && invoice && invoice.items && invoice.items.length) { %>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:16px; border:1px solid #E5E7EB; border-radius:8px; overflow:hidden;">
                <tr>
                  <td colspan="5" style="padding:12px 16px; border-bottom:1px solid #E5E7EB; background-color:#F9FAFB;">
                    <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6B7280;">Pozycje faktury</p>
                  </td>
                </tr>
                <tr style="background-color:#F9FAFB;">
                  <td style="padding:10px 16px; font-size:11px; font-weight:700; color:#6B7280; border-bottom:1px solid #E5E7EB; text-transform:uppercase; letter-spacing:0.5px;">Opis</td>
                  <td style="padding:10px 8px; font-size:11px; font-weight:700; color:#6B7280; border-bottom:1px solid #E5E7EB; text-align:center; text-transform:uppercase; letter-spacing:0.5px;">Ilość</td>
                  <td style="padding:10px 8px; font-size:11px; font-weight:700; color:#6B7280; border-bottom:1px solid #E5E7EB; text-align:right; text-transform:uppercase; letter-spacing:0.5px;">Cena netto</td>
                  <td style="padding:10px 8px; font-size:11px; font-weight:700; color:#6B7280; border-bottom:1px solid #E5E7EB; text-align:center; text-transform:uppercase; letter-spacing:0.5px;">VAT</td>
                  <td style="padding:10px 16px; font-size:11px; font-weight:700; color:#6B7280; border-bottom:1px solid #E5E7EB; text-align:right; text-transform:uppercase; letter-spacing:0.5px;">Brutto</td>
                </tr>
                <% invoice.items.forEach(function(item, i) { %>
                <tr>
                  <td style="padding:13px 16px; <%= i < invoice.items.length - 1 ? 'border-bottom:1px solid #F3F4F6;' : '' %> font-size:13px; color:#111827;"><%= item.description %></td>
                  <td style="padding:13px 8px; <%= i < invoice.items.length - 1 ? 'border-bottom:1px solid #F3F4F6;' : '' %> font-size:13px; color:#6B7280; text-align:center;"><%= item.quantity %> <%= item.unit %></td>
                  <td style="padding:13px 8px; <%= i < invoice.items.length - 1 ? 'border-bottom:1px solid #F3F4F6;' : '' %> font-size:13px; color:#111827; text-align:right; white-space:nowrap;"><%= item.unitPriceNet.toFixed(2) %> <%= invoice.totals.currency %></td>
                  <td style="padding:13px 8px; <%= i < invoice.items.length - 1 ? 'border-bottom:1px solid #F3F4F6;' : '' %> font-size:13px; color:#6B7280; text-align:center;"><%= item.vatRate %>%</td>
                  <td style="padding:13px 16px; <%= i < invoice.items.length - 1 ? 'border-bottom:1px solid #F3F4F6;' : '' %> font-size:13px; font-weight:600; color:#111827; text-align:right; white-space:nowrap;"><%= item.grossAmount.toFixed(2) %> <%= invoice.totals.currency %></td>
                </tr>
                <% }); %>
              </table>
              <% } %>

              <!-- Totals -->
              <% if (typeof invoice !== 'undefined' && invoice && invoice.totals) { %>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:24px; border:1px solid #E5E7EB; border-radius:8px;">
                <tr>
                  <td colspan="2" style="padding:12px 20px; border-bottom:1px solid #E5E7EB; background-color:#F9FAFB;">
                    <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#6B7280;">Podsumowanie</p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280; width:55%;">Wartość netto</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:500; color:#111827; text-align:right; white-space:nowrap;"><%= invoice.totals.totalNet.toFixed(2) %> <%= invoice.totals.currency %></td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280;">Kwota VAT</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:500; color:#111827; text-align:right; white-space:nowrap;"><%= invoice.totals.totalVat.toFixed(2) %> <%= invoice.totals.currency %></td>
                </tr>
                <tr style="background-color:#ECFDF5;">
                  <td style="padding:14px 20px; font-size:14px; font-weight:700; color:#065F46;">Wartość brutto</td>
                  <td style="padding:14px 20px; font-size:18px; font-weight:700; color:#059669; text-align:right; white-space:nowrap;"><%= invoice.totals.totalGross.toFixed(2) %> <%= invoice.totals.currency %></td>
                </tr>
              </table>
              <% } %>

              <!-- Notes -->
              <% if (typeof invoice !== 'undefined' && invoice && invoice.notes) { %>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:24px; border:1px solid #FEF3C7; border-radius:8px; background-color:#FFFBEB;">
                <tr>
                  <td style="padding:14px 20px;">
                    <p style="margin:0 0 4px 0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#92400E;">Uwagi</p>
                    <p style="margin:0; font-size:13px; color:#78350F; line-height:1.6;"><%= invoice.notes %></p>
                  </td>
                </tr>
              </table>
              <% } %>

              <p style="margin:0 0 6px 0; font-size:15px; line-height:1.7; color:#4B5563;">
                Pełna faktura w formacie PDF została dołączona do tej wiadomości. W razie pytań prosimy o kontakt.
              </p>
              <p style="margin:16px 0 0 0; font-size:14px; color:#4B5563;">
                Serdecznie,<br />
                <strong style="color:#111827;">Zespół <%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></strong>
              </p>
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td style="background-color:#F9FAFB; border-top:1px solid #E5E7EB; padding:24px 32px; text-align:center;">
              <p style="margin:0 0 4px 0; font-size:13px; font-weight:600; color:#374151;"><%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></p>
              <% if (typeof hotel !== 'undefined' && hotel && hotel.address) { %>
              <p style="margin:0 0 2px 0; font-size:12px; color:#9CA3AF;"><%= hotel.address %></p>
              <% } %>
              <% if (typeof hotel !== 'undefined' && hotel && hotel.phone) { %>
              <p style="margin:0 0 2px 0; font-size:12px; color:#9CA3AF;"><%= hotel.phone %></p>
              <% } %>
              <% if (typeof hotel !== 'undefined' && hotel && hotel.email) { %>
              <p style="margin:0; font-size:12px; color:#9CA3AF;"><a href="mailto:<%= hotel.email %>" style="color:#9CA3AF; text-decoration:none;"><%= hotel.email %></a></p>
              <% } %>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
