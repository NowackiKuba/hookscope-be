<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Rezerwacja anulowana — Pokoje Borowa</title>
</head>
<body style="margin:0; padding:0; background-color:#F0F2F5; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#F0F2F5;">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:600px;">

          <!-- HEADER -->
          <tr>
            <td style="background-color:#111827; padding:28px 32px; text-align:center;">
              <p style="margin:0 0 6px 0; font-size:10px; font-weight:700; letter-spacing:3px; color:#6EE7B7; text-transform:uppercase;">Pokoje w górach</p>
              <p style="margin:0; font-size:26px; font-weight:700; color:#FFFFFF; letter-spacing:-0.5px;"><%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></p>
            </td>
          </tr>

          <!-- HERO -->
          <tr>
            <td style="background-color:#7F1D1D; padding:32px; text-align:center;">
              <p style="margin:0 0 12px 0; font-size:40px; line-height:1;">❌</p>
              <p style="margin:0; font-size:22px; font-weight:700; color:#FFFFFF; line-height:1.3;">Rezerwacja anulowana</p>
            </td>
          </tr>

          <!-- CONTENT -->
          <tr>
            <td style="background-color:#FFFFFF; padding:40px 32px;">

              <p style="margin:0 0 8px 0; font-size:17px; font-weight:600; color:#111827;">
                Cześć, <%= typeof guest !== 'undefined' && guest && guest.firstName ? guest.firstName : 'Gościu' %>.
              </p>
              <p style="margin:0 0 32px 0; font-size:15px; line-height:1.7; color:#4B5563;">
                Informujemy, że Twoja rezerwacja w <%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %> została anulowana.
              </p>

              <!-- Cancelled reservation details -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:24px; border:1px solid #E5E7EB; border-radius:8px;">
                <tr>
                  <td colspan="2" style="padding:12px 20px; border-bottom:1px solid #E5E7EB; background-color:#FEF2F2;">
                    <p style="margin:0; font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#991B1B;">Anulowana rezerwacja</p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280; width:45%;">Numer rezerwacji</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:700; color:#111827; text-align:right;"><%= typeof reservation !== 'undefined' && reservation && reservation.id ? reservation.id : '—' %></td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:13px; color:#6B7280;">Zameldowanie</td>
                  <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; font-size:14px; font-weight:600; color:#6B7280; text-align:right; text-decoration:line-through;"><%= typeof reservation !== 'undefined' && reservation && reservation.checkIn ? reservation.checkIn : '—' %></td>
                </tr>
                <tr>
                  <td style="padding:13px 20px; font-size:13px; color:#6B7280;">Wymeldowanie</td>
                  <td style="padding:13px 20px; font-size:14px; font-weight:600; color:#6B7280; text-align:right; text-decoration:line-through;"><%= typeof reservation !== 'undefined' && reservation && reservation.checkOut ? reservation.checkOut : '—' %></td>
                </tr>
              </table>

              <!-- Help banner -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:32px; background-color:#F9FAFB; border:1px solid #E5E7EB; border-radius:8px;">
                <tr>
                  <td style="padding:20px;">
                    <p style="margin:0 0 12px 0; font-size:14px; font-weight:700; color:#111827;">Masz pytania?</p>
                    <p style="margin:0 0 16px 0; font-size:14px; line-height:1.6; color:#4B5563;">
                      Jeśli anulowanie nastąpiło przez pomyłkę lub chcesz złożyć nową rezerwację, skontaktuj się z nami — chętnie pomożemy.
                    </p>
                    <p style="margin:0 0 6px 0; font-size:13px; font-weight:600; color:#374151;"><%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></p>
                    <% if (typeof hotel !== 'undefined' && hotel && hotel.phone) { %>
                    <p style="margin:0 0 4px 0; font-size:13px; color:#4B5563;">
                      📞 <a href="tel:<%= hotel.phone %>" style="color:#2D6A4F; text-decoration:none; font-weight:600;"><%= hotel.phone %></a>
                    </p>
                    <% } %>
                    <% if (typeof hotel !== 'undefined' && hotel && hotel.email) { %>
                    <p style="margin:0; font-size:13px; color:#4B5563;">
                      ✉️ <a href="mailto:<%= hotel.email %>" style="color:#2D6A4F; text-decoration:none; font-weight:600;"><%= hotel.email %></a>
                    </p>
                    <% } %>
                  </td>
                </tr>
              </table>

              <p style="margin:0 0 6px 0; font-size:15px; line-height:1.7; color:#4B5563;">
                Mamy nadzieję, że odwiedzi nas Pan/Pani przy innej okazji.
              </p>
              <p style="margin:16px 0 0 0; font-size:14px; color:#4B5563;">
                Serdecznie,<br />
                <strong style="color:#111827;">Zespół <%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></strong>
              </p>
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td style="background-color:#F9FAFB; border-top:1px solid #E5E7EB; padding:24px 32px; text-align:center;">
              <p style="margin:0 0 4px 0; font-size:13px; font-weight:600; color:#374151;"><%= typeof hotel !== 'undefined' && hotel && hotel.name ? hotel.name : 'Pokoje Borowa' %></p>
              <% if (typeof hotel !== 'undefined' && hotel && hotel.phone) { %>
              <p style="margin:0 0 2px 0; font-size:12px; color:#9CA3AF;"><%= hotel.phone %></p>
              <% } %>
              <% if (typeof hotel !== 'undefined' && hotel && hotel.email) { %>
              <p style="margin:0; font-size:12px; color:#9CA3AF;"><a href="mailto:<%= hotel.email %>" style="color:#9CA3AF; text-decoration:none;"><%= hotel.email %></a></p>
              <% } %>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
