<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>You're on the list — Hookscope</title>
</head>
<body style="margin:0; padding:0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background-color: #f0f0f5; color: #0d0d14;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color: #f0f0f5;">
    <tr>
      <td align="center" style="padding: 48px 20px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width: 480px; margin: 0 auto;">

          <!-- Header -->
          <tr>
            <td align="center" style="padding-bottom: 24px;">
              <span style="font-size: 18px; font-weight: 700; letter-spacing: -0.3px; color: #0d0d14;">
                hook<span style="color: #7c3aed;">scope</span>
              </span>
            </td>
          </tr>

          <!-- Card -->
          <tr>
            <td style="background-color: #ffffff; border-radius: 14px; border: 1px solid #e5e5eb; padding: 40px 36px; box-shadow: 0 1px 4px rgba(0,0,0,0.05);">

              <!-- Badge -->
              <div style="display: inline-block; background-color: #ede9fe; color: #6d28d9; font-size: 11px; font-weight: 600; letter-spacing: 0.4px; text-transform: uppercase; padding: 5px 12px; border-radius: 999px; margin-bottom: 28px;">
                You're on the list
              </div>

              <!-- Heading -->
              <h1 style="margin: 0 0 16px 0; font-size: 22px; font-weight: 700; line-height: 1.3; letter-spacing: -0.3px; color: #0d0d14;">
                Thanks for joining the waitlist
              </h1>

              <!-- Body -->
              <p style="margin: 0 0 28px 0; font-size: 15px; line-height: 1.65; color: #52525b;">
                We've added <strong style="color: #0d0d14;"><%= typeof email !== 'undefined' ? email : 'you' %></strong> to the waitlist.
                We'll reach out as soon as a spot opens up.
              </p>

              <!-- Divider -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin: 0 0 28px 0;">
                <tr>
                  <td style="border-top: 1px solid #e5e5eb; font-size: 0; line-height: 0;">&nbsp;</td>
                </tr>
              </table>

              <!-- What to expect -->
              <p style="margin: 0 0 12px 0; font-size: 13px; font-weight: 600; letter-spacing: 0.2px; color: #0d0d14;">What to expect</p>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="padding: 6px 0;">
                    <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="width: 20px; vertical-align: top; padding-top: 1px;">
                          <span style="display: inline-block; width: 6px; height: 6px; background-color: #7c3aed; border-radius: 50%; margin-top: 5px;"></span>
                        </td>
                        <td style="font-size: 14px; line-height: 1.55; color: #52525b;">Early access to the Hookscope platform</td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding: 6px 0;">
                    <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="width: 20px; vertical-align: top; padding-top: 1px;">
                          <span style="display: inline-block; width: 6px; height: 6px; background-color: #7c3aed; border-radius: 50%; margin-top: 5px;"></span>
                        </td>
                        <td style="font-size: 14px; line-height: 1.55; color: #52525b;">A personal invite the moment we're ready</td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding: 6px 0;">
                    <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="width: 20px; vertical-align: top; padding-top: 1px;">
                          <span style="display: inline-block; width: 6px; height: 6px; background-color: #7c3aed; border-radius: 50%; margin-top: 5px;"></span>
                        </td>
                        <td style="font-size: 14px; line-height: 1.55; color: #52525b;">No spam — just the essentials</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Divider -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin: 28px 0;">
                <tr>
                  <td style="border-top: 1px solid #e5e5eb; font-size: 0; line-height: 0;">&nbsp;</td>
                </tr>
              </table>

              <!-- Sign-off -->
              <p style="margin: 0; font-size: 13px; color: #a1a1aa;">
                — The Hookscope team
              </p>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding-top: 24px;">
              <p style="margin: 0; font-size: 12px; color: #a1a1aa; line-height: 1.6;">
                You received this email because you signed up for the Hookscope waitlist.<br />
                If this wasn't you, you can safely ignore this message.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
